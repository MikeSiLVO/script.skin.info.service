							<top>40</top>
							<width>1360</width>
							<height>40</height>
							<font>font13</font>
							<textcolor>silver</textcolor>
							<textoffsetx>10</textoffsetx>
							<label>$INFO[Window.Property(KnownFor)]$INFO[Window.Property(Gender), · ]$INFO[Window.Property(Age), · , years]</label>
