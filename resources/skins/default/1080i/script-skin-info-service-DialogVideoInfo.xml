<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
	<defaultcontrol always="true">5001</defaultcontrol>
	<controls>
		<control type="group">
			<animation effect="fade" start="0" end="100" time="300">WindowOpen</animation>
			<animation effect="fade" start="100" end="0" time="200">WindowClose</animation>
			<!-- Background -->
			<control type="image">
				<width>100%</width>
				<height>100%</height>
				<texture colordiffuse="FF000000">colors/white.png</texture>
			</control>
			<!-- Fanart -->
			<control type="image">
				<width>100%</width>
				<height>100%</height>
				<texture background="true" colordiffuse="33FFFFFF">$INFO[Window.Property(Fanart)]</texture>
				<aspectratio>scale</aspectratio>
			</control>
			<control type="group">
				<left>50</left>
				<top>40</top>
				<width>1820</width>
				<height>1000</height>
				<control type="group">
					<animation effect="slide" start="0" end="0,-700" time="500" tween="cubic" easing="inout" condition="ControlGroup(5000).HasFocus">Conditional</animation>
					<!-- Poster -->
					<control type="image">
						<width>350</width>
						<height>525</height>
						<texture fallback="DefaultVideo.png" background="true">$INFO[Window.Property(Poster)]</texture>
						<aspectratio>scale</aspectratio>
					</control>
					<!-- Video info -->
					<control type="group">
						<left>440</left>
						<control type="label">
							<width>1360</width>
							<height>40</height>
							<font>font13</font>
							<textcolor>white</textcolor>
							<textoffsetx>10</textoffsetx>
							<label>[B]$INFO[Window.Property(Title)][/B]$INFO[Window.Property(Year), (,)]</label>
						</control>
						<control type="label">
							<top>40</top>
							<width>1360</width>
							<height>40</height>
							<font>font13</font>
							<textcolor>silver</textcolor>
							<textoffsetx>10</textoffsetx>
							<label>$INFO[Window.Property(Genre)]$INFO[Window.Property(Runtime), · ]$INFO[Window.Property(MPAA), · ]</label>
						</control>
						<control type="label">
							<top>80</top>
							<width>1360</width>
							<height>40</height>
							<font>font13</font>
							<textcolor>silver</textcolor>
							<textoffsetx>10</textoffsetx>
							<label>$INFO[Window.Property(Rating.tmdb),TMDB: ]$INFO[Window.Property(Rating.imdb), · IMDb: ]$INFO[Window.Property(Rating.trakt), · Trakt: ]</label>
						</control>
						<control type="label">
							<top>120</top>
							<width>1360</width>
							<height>40</height>
							<font>font13</font>
							<textcolor>darkgray</textcolor>
							<textoffsetx>10</textoffsetx>
							<visible>!String.IsEmpty(Window.Property(Tagline))</visible>
							<label>[I]$INFO[Window.Property(Tagline)][/I]</label>
						</control>
						<!-- Plot -->
						<control type="group">
							<top>180</top>
							<width>1360</width>
							<height>300</height>
							<control type="textbox">
								<left>10</left>
								<width>1350</width>
								<height>256</height>
								<font>font13</font>
								<textcolor>whitesmoke</textcolor>
								<label>$INFO[Window.Property(Plot)]</label>
								<autoscroll delay="6000" time="3000" repeat="10000">true</autoscroll>
							</control>
							<control type="button" id="5001">
								<top>-10</top>
								<width>1360</width>
								<height>276</height>
								<texturefocus colordiffuse="40FFFFFF">colors/white.png</texturefocus>
								<texturenofocus />
								<label />
								<onclick>RunScript(script.skin.info.service,dialog=textviewer,heading=$ESCINFO[Window.Property(Title)],text=$ESCINFO[Window.Property(Plot)])</onclick>
								<ondown>5000</ondown>
							</control>
						</control>
						<control type="label">
							<top>450</top>
							<width>1360</width>
							<height>40</height>
							<font>font13</font>
							<textcolor>silver</textcolor>
							<textoffsetx>10</textoffsetx>
							<visible>!String.IsEmpty(Window.Property(Director)) | !String.IsEmpty(Window.Property(Writer))</visible>
